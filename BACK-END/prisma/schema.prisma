generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  cep      String
  adm      Boolean @default(false)
}

model product {
   id       String  @id @default(cuid())
   name     String
   description String
   price Int
   img String
   category String 
   createdAt DateTime @default(now())

}
